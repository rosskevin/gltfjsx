{
  "author": "Paul Henschel",
  "auto": {
    "plugins": [
      [
        "npm",
        {
          "setRcToken": false
        }
      ],
      "all-contributors",
      "first-time-contributor",
      "released"
    ]
  },
  "bin": "./dist/cli.mjs",
  "bugs": {
    "url": "https://github.com/rosskevin/gltfjsx/issues"
  },
  "collective": {
    "type": "opencollective",
    "url": "https://opencollective.com/react-three-fiber"
  },
  "dependencies": {
    "@biomejs/js-api": "^6.0.0",
    "@biomejs/wasm-nodejs": "^2.5.0",
    "@gltf-transform/core": "4.4.0",
    "@gltf-transform/extensions": "4.4.0",
    "@gltf-transform/functions": "4.4.0",
    "draco3dgltf": "^1.5.7",
    "es-toolkit": "^1.47.1",
    "is-var-name": "^2.0.0",
    "keyframe-resample": "^0.1.0",
    "meow": "^14.1.0",
    "meshoptimizer": "^1.1.1",
    "node-three-gltf": "2.1.0",
    "read-pkg-up": "^11.0.0",
    "sharp": "^0.35.1",
    "three": "0.184.0",
    "three-stdlib": "^2.36.1",
    "ts-morph": "^28.0.0"
  },
  "description": "GLTF to JSX converter",
  "devDependencies": {
    "@alienfast/biome-config": "^1.0.6",
    "@alienfast/tsconfig": "^1.0.8",
    "@auto-it/all-contributors": "^11.3.6",
    "@auto-it/first-time-contributor": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@biomejs/biome": "^2.5.0",
    "@types/draco3dgltf": "^1.4.3",
    "@types/node": "^25.9.3",
    "@types/three": "^0.184.1",
    "auto": "^11.3.6",
    "chalk": "^5.6.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "markdownlint-cli2": "^0.22.1",
    "npm-run-all": "^4.1.5",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "homepage": "https://github.com/rosskevin/gltfjsx#readme",
  "keywords": [
    "gltf",
    "jsx",
    "react",
    "fiber",
    "three",
    "threejs",
    "webp"
  ],
  "license": "MIT",
  "name": "@rosskevin/gltfjsx",
  "optionalDependencies": {
    "libvips": "^0.0.2"
  },
  "packageManager": "pnpm@11.8.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rosskevin/gltfjsx.git"
  },
  "scripts": {
    "build": "tsdown",
    "check": "run-p -c --aggregate-output check-types check-biome check-circular check-markdown test",
    "check-biome": "biome check --write",
    "check-circular": "madge --circular --extensions ts ./src --ts-config ./tsconfig.json",
    "check-markdown": "markdownlint-cli2 --fix \"**/*.md\"",
    "check-types": "tsc --noEmit",
    "release": "auto shipit",
    "test": "vitest run"
  },
  "type": "module",
  "version": "7.3.0"
}
